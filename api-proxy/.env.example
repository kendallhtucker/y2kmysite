# Copy this file to .env.local and fill in your values.
# .env.local is gitignored.

# Required: your OpenAI API key (starts with sk-...)
OPENAI_API_KEY=sk-replace-me

# Optional: override the allowed CORS origin (defaults to https://kendallhtucker.github.io)
# ALLOWED_ORIGIN=https://kendallhtucker.github.io

# These are auto-injected by Vercel KV when you attach a KV store to the project.
# Only set them manually if you're testing KV locally.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
